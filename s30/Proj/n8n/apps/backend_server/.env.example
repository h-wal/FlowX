# Server
PORT=3030

# CORS: allow frontend origin (set in production to your frontend URL, e.g. https://yourapp.vercel.app)
# CORS_ORIGIN=http://localhost:3000

# Auth (required)
# JWT_KEY=your-secret-key

# Redis (required for workflow execution – backend adds jobs, worker processes them)
# For local: run Redis (e.g. brew install redis) or use REDIS_URL from Upstash
# REDIS_URL=redis://default:xxx@xxx.upstash.io:6379
